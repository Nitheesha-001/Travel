projection;
strict ( 2 );
use draft;
use side effects;

define behavior for ZUJ_EXCEL_USER_C alias XLHead
{
  use create;
  use update;
  use delete;

  use action UploadExcelData;

  use action Activate;
  use action Discard;
  use action Edit;
  use action Resume;
  use action Prepare;

  use association _XLData { create; with draft; }
}

define behavior for ZUJ_EXCEL_DATA_C alias XLData
{
  use update;
  use delete;

  use association _XLUser { with draft; }
}