@Metadata.layer: #CORE
annotate entity ZUJ_ADDRESS_C
    with 
{

@UI.facet: [{ id: 'Address',
              purpose: #STANDARD,
              type: #IDENTIFICATION_REFERENCE,
              label: 'Address',
              position: 10
              }]

@UI.hidden: true
    AddrnumberUuid;
    @UI.hidden: true
    EnrollUuid;
    @UI.hidden: true
    ShippingUuid;
    @UI.hidden: true
    Addrnumber;
    @UI:{ lineItem: [{ position:10, importance:#HIGH, label: 'Street1' }] }
  @UI:{ identification: [{position:10, importance:#HIGH, label: 'Street1' }] }
    Street1;
    @UI:{ lineItem: [{ position:20, importance:#HIGH, label: 'Street2' }] }
  @UI:{ identification: [{position:20, importance:#HIGH, label: 'Street2' }] }
    Street2;
    @UI:{ lineItem: [{ position:30, importance:#HIGH, label: 'City' }] }
  @UI:{ identification: [{position:30, importance:#HIGH, label: 'City' }] }
    City;
    @UI:{ lineItem: [{ position:40, importance:#HIGH, label: 'State' }] }
  @UI:{ identification: [{position:40, importance:#HIGH, label: 'State' }] }
    State;
    @UI:{ lineItem: [{ position:50, importance:#HIGH, label: 'Country' }] }
  @UI:{ identification: [{position:50, importance:#HIGH, label: 'Country' }] }
    Country;
    @UI:{ lineItem: [{ position:60, importance:#HIGH, label: 'Zipcode' }] }
  @UI:{ identification: [{position:60, importance:#HIGH, label: 'Zipcode' }] }
    Zipcode;
//    LocalLastChangedAt;
//    /* Associations */
//    _Enroll;
//    _Ship;
    
}